generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Contact {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  service   String?
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  read      Boolean  @default(false)

  @@map("contacts")
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  active    Boolean  @default(true)

  @@map("subscribers")
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  excerpt     String   @db.Text
  content     String   @db.LongText
  coverImage  String?
  tags        String   @default("[]")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  tags        String   @default("[]")
  image       String?
  github      String?
  demo        String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("projects")
}

model SiteConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String @db.Text
  group String

  @@map("site_config")
}